{
  "manifest_version": 3,
  "name": "AI Query Inspector",
  "version": "1.8.5",
  "description": "Local-only AI query inspector for ChatGPT conversations plus local search capture, full-page dashboard, source labeling, and comprehensive exports.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "AI Query Inspector",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://www.bing.com/*",
    "https://duckduckgo.com/*",
    "https://www.google.com/*",
    "https://www.google.lk/*",
    "https://www.google.co.uk/*",
    "https://www.google.ca/*",
    "https://www.google.com.au/*",
    "https://www.google.co.in/*",
    "https://www.google.co.jp/*",
    "https://www.google.com.sg/*",
    "https://www.google.co.nz/*",
    "https://www.google.co.za/*",
    "https://www.google.ae/*",
    "https://www.google.com.sa/*",
    "https://www.google.com.my/*",
    "https://www.google.com.ph/*",
    "https://www.google.com.hk/*",
    "https://www.google.com.tw/*",
    "https://www.google.com.br/*",
    "https://www.google.com.mx/*",
    "https://www.google.com.ar/*",
    "https://www.google.cl/*",
    "https://www.google.com.co/*",
    "https://www.google.com.pe/*",
    "https://www.google.de/*",
    "https://www.google.fr/*",
    "https://www.google.es/*",
    "https://www.google.it/*",
    "https://www.google.nl/*",
    "https://www.google.be/*",
    "https://www.google.ch/*",
    "https://www.google.at/*",
    "https://www.google.se/*",
    "https://www.google.no/*",
    "https://www.google.fi/*",
    "https://www.google.dk/*",
    "https://www.google.ie/*",
    "https://www.google.pl/*",
    "https://www.google.pt/*",
    "https://www.google.gr/*",
    "https://www.google.cz/*",
    "https://www.google.sk/*",
    "https://www.google.hu/*",
    "https://www.google.ro/*",
    "https://www.google.bg/*",
    "https://www.google.hr/*",
    "https://www.google.si/*",
    "https://www.google.rs/*",
    "https://www.google.com.tr/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}