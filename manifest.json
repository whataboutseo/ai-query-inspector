{
  "manifest_version": 3,
  "name": "AI Query Inspector",
  "version": "1.0.2",
  "description": "Compare what ChatGPT cites against Google, Bing, or DuckDuckGo rankings — locally, on-device, with zero data leaving your browser.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "AI Query Inspector",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://*.google.com/*",
    "https://www.bing.com/*",
    "https://duckduckgo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
