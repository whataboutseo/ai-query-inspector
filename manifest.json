{
  "manifest_version": 3,
  "name": "AI Query Inspector Claude",
  "version": "1.9.4",
  "description": "Local-only AI query inspector for ChatGPT conversations plus local search capture, full-page dashboard, source labeling, and comprehensive exports. Claude-authored rework of the original tool.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "AI Query Inspector Claude",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://*.google.com/*",
    "https://www.bing.com/*",
    "https://duckduckgo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
